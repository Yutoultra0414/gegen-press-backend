rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザーコレクション
    match /users/{userId} {
      allow get: if true; // マイページの個別閲覧（?id=）用。1件ずつの取得は誰でも可能
      allow list: if request.auth != null && request.auth.uid == 'EcFjXMp6rpODK9i8E1DN1CPjZov2'; // 全件一覧の取得は管理者のみ（メールアドレス一括流出防止）
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // 記事コレクション
    // 管理者UIDは EcFjXMp6rpODK9i8E1DN1CPjZov2 に設定済み（別のFirebaseプロジェクト/アカウントを使う場合は要変更）
    match /articles/{articleId} {
      allow read: if true; // すべての人が閲覧可能
      allow create: if request.auth != null;
      // 閲覧数(views)だけは、未ログインの読者も含め誰でも増やせるようにする
      allow update: if (request.auth != null
                    && (request.auth.uid == resource.data.authorId
                        || request.auth.uid == 'EcFjXMp6rpODK9i8E1DN1CPjZov2'))
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']);
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.authorId
                        || request.auth.uid == 'EcFjXMp6rpODK9i8E1DN1CPjZov2');
    }

    // コメントコレクション（投稿はログイン必須）
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.userId;
    }

    // 評価コレクション（記事・記者評価はログイン不要で投稿可能）
    match /ratings/{ratingId} {
      allow read: if true;
      // ログイン必須。ドキュメントIDは articleId_userId 固定なので、
      // 本人のUIDと一致するIDでしか作成・上書きできない（＝1アカウント1記事1回）
      allow create, update: if request.auth != null
                            && request.auth.uid == request.resource.data.userId
                            && ratingId == request.resource.data.articleId + '_' + request.auth.uid;
      allow delete: if request.auth != null
                            && request.auth.uid == resource.data.userId;
    }

    // 記者コレクション（ログインユーザーが追加可能・追加者本人と管理者が編集可能）
    // 管理者UIDは EcFjXMp6rpODK9i8E1DN1CPjZov2 に設定済み
    match /reporters/{reporterId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.createdBy
                        || request.auth.uid == 'EcFjXMp6rpODK9i8E1DN1CPjZov2');
      allow delete: if request.auth != null && request.auth.uid == 'EcFjXMp6rpODK9i8E1DN1CPjZov2';
    }

    // 選手コレクション（記者と同じ方式：ログインユーザーが追加可能・追加者本人と管理者が編集可能）
    match /players/{playerId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.createdBy
                        || request.auth.uid == 'EcFjXMp6rpODK9i8E1DN1CPjZov2');
      allow delete: if request.auth != null && request.auth.uid == 'EcFjXMp6rpODK9i8E1DN1CPjZov2';
    }

    // 記者へのレビュー（クチコミ）
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      // 本人はレビュー全体を編集・削除可能。それ以外のログインユーザーは
      // いいね/うーんのカウント(likes/dislikes)のみ更新可能
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // レビューへのいいね/うーん投票（1アカウント1レビュー1票。ドキュメントID＝reviewId_uid）
    match /reviewVotes/{voteId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // フォロー関係コレクション
    match /follows/{followId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.followerId;
    }

    // クラブ（ロゴ画像のみ保持。ドキュメントID＝クラブ名。ログインしていれば誰でもロゴを設定・更新可能）
    match /clubs/{clubName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // メディア（媒体そのものを登録するコレクション。ドキュメントID＝メディア名）
    match /media/{mediaName} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && (request.auth.uid == resource.data.createdBy
                                || request.auth.uid == 'EcFjXMp6rpODK9i8E1DN1CPjZov2');
    }
  }
}
