rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 管理者UID一覧はここに集約しています。管理者を増やしたい場合はこの配列に追記してください。
    function isAdmin() {
      return request.auth != null
        && request.auth.uid in ['EcFjXMp6rpODK9i8E1DN1CPjZov2', 'DKjQNLTtVldXTMEXFQ1TJiOaxNE2'];
    }

    // ユーザーコレクション
    match /users/{userId} {
      allow get: if true; // マイページの個別閲覧（?id=）用。1件ずつの取得は誰でも可能
      allow list: if isAdmin(); // 全件一覧の取得は管理者のみ（メールアドレス一括流出防止）
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // 記事コレクション
    match /articles/{articleId} {
      allow read: if true; // すべての人が閲覧可能
      allow create: if request.auth != null;
      // 閲覧数(views)だけは、未ログインの読者も含め誰でも増やせるようにする
      allow update: if (request.auth != null
                    && (request.auth.uid == resource.data.authorId || isAdmin()))
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']);
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    // コメントコレクション（投稿はログイン必須）
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // 評価コレクション（記事・記者評価はログイン不要で投稿可能）
    match /ratings/{ratingId} {
      allow read: if true;
      // ログイン必須。ドキュメントIDは articleId_userId 固定なので、
      // 本人のUIDと一致するIDでしか作成・上書きできない（＝1アカウント1記事1回）
      allow create, update: if request.auth != null
                            && request.auth.uid == request.resource.data.userId
                            && ratingId == request.resource.data.articleId + '_' + request.auth.uid;
      allow delete: if request.auth != null
                            && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // 記者コレクション（ログインユーザーが追加可能・追加者本人と管理者が編集可能）
    match /reporters/{reporterId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.createdBy || isAdmin());
      allow delete: if isAdmin();
    }

    // 選手コレクション（記者と同じ方式：ログインユーザーが追加可能・追加者本人と管理者が編集可能）
    match /players/{playerId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.createdBy || isAdmin());
      allow delete: if isAdmin();
    }

    // 記者へのレビュー（クチコミ）
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      // 本人・管理者はレビュー全体を編集・削除可能。それ以外のログインユーザーは
      // いいね/うーんのカウント(likes/dislikes)のみ更新可能
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes'])
      );
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // レビューへのいいね/うーん投票（1アカウント1レビュー1票。ドキュメントID＝reviewId_uid）
    match /reviewVotes/{voteId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // フォロー関係コレクション
    match /follows/{followId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.followerId || isAdmin());
    }

    // クラブマスタ（ドキュメントID＝clubId。クラブ名・国・リーグ・ロゴなどをまとめて保持。
    // 表記ゆれの吸収に使うaliasesを含め、内容の信頼性が重要なため書き込みは管理者限定。
    match /clubs/{clubId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // リーグマスタ（ドキュメントID＝leagueId）。クラブマスタと同様に管理者限定。
    match /leagues/{leagueId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // メディア（媒体そのものを登録するコレクション。ドキュメントID＝メディア名）
    match /media/{mediaName} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && (request.auth.uid == resource.data.createdBy || isAdmin());
    }
  }
}
