rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザーコレクション
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // 記事コレクション
    // ※ 'YOUR_ADMIN_UID' は自分のユーザーUID（Authentication > Users で確認）に置き換えてください
    match /articles/{articleId} {
      allow read: if true; // すべての人が閲覧可能
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.authorId
                        || request.auth.uid == 'YOUR_ADMIN_UID');
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.authorId
                        || request.auth.uid == 'YOUR_ADMIN_UID');
    }

    // コメントコレクション（投稿はログイン必須）
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.userId;
    }

    // 評価コレクション（記事・記者評価はログイン不要で投稿可能）
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if true; // 誰でも評価可能
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.userId;
    }

    // 記者コレクション（ログインユーザーが追加可能・追加者本人と管理者が編集可能）
    // ※ 下の 'YOUR_ADMIN_UID' を、Firebaseコンソール > Authentication > Users で
    //   確認できる自分のユーザーUIDに置き換えてください（運営者として公式記者を編集・削除できるようになります）
    match /reporters/{reporterId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.createdBy
                        || request.auth.uid == 'YOUR_ADMIN_UID');
      allow delete: if request.auth != null && request.auth.uid == 'YOUR_ADMIN_UID';
    }

    // 選手コレクション（記者と同じ方式：ログインユーザーが追加可能・追加者本人と管理者が編集可能）
    match /players/{playerId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.createdBy
                        || request.auth.uid == 'YOUR_ADMIN_UID');
      allow delete: if request.auth != null && request.auth.uid == 'YOUR_ADMIN_UID';
    }

    // 記者へのレビュー（クチコミ）
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.userId;
    }

    // フォロー関係コレクション
    match /follows/{followId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.followerId;
    }

    // クラブ（ロゴ画像のみ保持。ドキュメントID＝クラブ名。ログインしていれば誰でもロゴを設定・更新可能）
    match /clubs/{clubName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
